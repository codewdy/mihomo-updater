# 订阅地址（必填，对应 config.docker.yaml 中的 url）
SUB_URL=

# 可选：REST API 密钥，留空表示不设置
SECRET=

DATA_PATH=./data

# 与宿主机用户一致（避免 data 目录 root 拥有）；可运行前执行 export HOST_UID=$(id -u) HOST_GID=$(id -g) 覆盖 .env
HOST_UID=1000
HOST_GID=1000

# 配置拉取间隔（秒）
CONFIG_UPDATE_INTERVAL=86400

# 面板 UI 下载地址
UI_URL=https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip

MIHOMO_UPDATER_IMAGE=ghcr.io/codewdy/mihomo-updater:latest

# 映射到宿主机的端口
HOST_PORT=7890
HOST_API_PORT=9090
